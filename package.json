{
  "name": "adhd-dev",
  "version": "0.1.0",
  "description": "CLI-integrated focus tool for ADHD developers",
  "type": "module",
  "bin": {
    "adhd-dev": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/hooks"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["adhd", "focus", "cli", "developer-tools", "claude-code"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
